        <div class="glass-card">
            <h3 class="section-title"><i class="fas fa-globe"></i> GLOBAL SEARCH ENGINE</h3>
            <p style="color: var(--text-muted); font-size: 13px; margin-bottom: 10px;">Powered by Google Custom Search</p>
            <div class="gcse-search"></div> </div>

        <div class="glass-card">
            <h3 class="section-title"><i class="fas fa-brain"></i> LUPIN NEURAL AI</h3>
            <div class="ai-response-area" id="ai-response">
                Greetings. I am your local neural AI assistant. Type "/ai hello" to begin.
            </div>
            <div class="ai-input-wrapper">
                <input type="text" id="ai-query" placeholder="Type a command (e.g. /ai hello)...">
                <button onclick="askNeuralAI()"><i class="fas fa-paper-plane"></i></button>
