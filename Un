                <button class="menu-btn" onclick="window.location.href='help.html'"><i class="fas fa-question-circle"></i> Help</button>
                <button class="menu-btn" onclick="window.location.href='chat.html'"><i class="fas fa-comments"></i> Chat</button>
                <button class="menu-btn whatsapp-btn" onclick="window.open('https://wa.me/255782754785', '_blank')"><i class="fab fa-whatsapp"></i> Dev Contact</button>
