    <header>
        <div class="logo">LUPIN UNIVERSE</div>
        <div class="header-controls">
            <button class="music-btn" onclick="toggleMusic()" id="musicToggleBtn"><i class="fas fa-play"></i></button>
            <div class="user-badge"><i class="fas fa-user-shield"></i> <span id="displayAgent">GUEST</span></div>
