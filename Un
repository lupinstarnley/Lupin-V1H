    <footer style="text-align: center; padding: 40px; border-top: 1px solid var(--glass-border); margin-top: 20px;">
        <p>Crafted with <span style="color: #ff2a5f;">♥</span> in Tanzania</p>
        <p style="margin-top: 10px;">© <span style="color: var(--primary); font-weight: bold;">2026</span></p>
        <span style="font-family: 'Dancing Script', cursive; font-size: 35px; color: var(--secondary);">Lupin Starnley Jimmoh</span>
    </footer>

    <script>
        // ================= STAR GENERATOR =================
        function generateStars() {
            const space = document.getElementById('universe-bg');
            for (let i = 0; i < 100; i++) {
                let star = document.createElement('div');
                star.className = 'star';
                let size = Math.random() * 2;
                star.style.width = size + 'px'; star.style.height = size + 'px';
                star.style.left = Math.random() * 100 + 'vw'; star.style.top = Math.random() * 100 + 'vh';
                star.style.animationDuration = (Math.random() * 3 + 1) + 's';
                space.appendChild(star);
            }
        }
        generateStars();

        // ================= LOGIN & USERNAME SYSTEM =================
        const overlay = document.getElementById('login-overlay');
        const userDisplay = document.getElementById('displayAgent');
        let currentUser = localStorage.getItem('systemUser');

        if(currentUser) {
            overlay.style.display = 'none';
            userDisplay.innerText = currentUser.toUpperCase();
        }

        function verifyLogin() {
            const email = document.getElementById('logEmail').value;
            const user = document.getElementById('logUser').value;
            const pass = document.getElementById('logPass').value;
            const confirm = document.getElementById('logConfirm').value;
            const err = document.getElementById('logError');

            if(!email || !user || !pass || !confirm) {
                err.innerText = "Please fill all fields!";
                err.style.display = "block";
                return;
            }

            if(pass !== confirm) {
                err.innerText = "Passwords do not match!";
                err.style.display = "block";
            } else {
                localStorage.setItem('systemUser', user);
                userDisplay.innerText = user.toUpperCase();
                overlay.style.display = 'none';
                
                // Anza kuandika bio baada ya ku-login
                document.getElementById('typewriter-bio').innerHTML = "";
                i = 0; 
                typeWriterBio();
            }
        }

        function logoutSystem() {
            localStorage.removeItem('systemUser');
            window.location.href = "https://www.google.com";
        }

        // ================= MUSIC PLAYER =================
        const music = document.getElementById("bg-music");
        const musicBtn = document.getElementById("musicToggleBtn");
        let isPlaying = false;

        function toggleMusic() {
            if (isPlaying) {
                music.pause();
                musicBtn.innerHTML = '<i class="fas fa-play"></i>';
                musicBtn.style.color = "var(--primary)";
            } else {
                music.play().catch(e => console.log("Browser autoplay restriction."));
                musicBtn.innerHTML = '<i class="fas fa-pause"></i>';
                musicBtn.style.color = "#00ff41";
            }
            isPlaying = !isPlaying;
        }

