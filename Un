    </header>

    <div class="main-container">
        
        <div class="glass-card">
            <h3 class="section-title"><i class="fas fa-th-large"></i> SYSTEM MODULES</h3>
            <div class="grid-menu">
                <button class="menu-btn" onclick="window.location.href='movies.html'"><i class="fas fa-film"></i> Movies</button>
                <button class="menu-btn" onclick="window.location.href='hack.html'"><i class="fas fa-skull-crossbones"></i> Hacking</button>
                <button class="menu-btn" onclick="window.location.href='games.html'"><i class="fas fa-gamepad"></i> Games</button>
                <button class="menu-btn" onclick="window.location.href='advise.html'"><i class="fas fa-lightbulb"></i> Advise</button>
